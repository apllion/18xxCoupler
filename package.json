  "version": "0.5.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "build:pp": "VITE_PLUSPLUS=1 vite build",
    "deploy:coupler": "vite build && gh-pages -d dist",
